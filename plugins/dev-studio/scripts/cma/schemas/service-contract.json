{
  "type": "object",
  "required": ["service", "status", "acceptance_criteria"],
  "additionalProperties": false,
  "properties": {
    "service": { "type": "string", "maxLength": 80, "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "summary": { "type": "string", "maxLength": 400 },
    "status": { "enum": ["draft", "ready", "blocked"] },
    "surfaces": {
      "type": "array",
      "maxItems": 10,
      "items": { "enum": ["backend-go", "backend-python", "frontend", "proto", "chart", "observability"] }
    },
    "apis": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["rpc", "description"],
        "additionalProperties": false,
        "properties": {
          "rpc": { "type": "string", "maxLength": 120, "pattern": "^[A-Za-z0-9_.]+/[A-Za-z0-9_]+$" },
          "description": { "type": "string", "maxLength": 240 },
          "auth": { "enum": ["public", "authenticated"] }
        }
      }
    },
    "scope": {
      "type": "array",
      "maxItems": 50,
      "items": { "type": "string", "maxLength": 200 }
    },
    "out_of_scope": {
      "type": "array",
      "maxItems": 50,
      "items": { "type": "string", "maxLength": 200 }
    },
    "dependencies": {
      "type": "array",
      "maxItems": 50,
      "items": { "type": "string", "maxLength": 200 }
    },
    "acceptance_criteria": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "required": ["criterion", "verification"],
        "additionalProperties": false,
        "properties": {
          "criterion": { "type": "string", "maxLength": 240 },
          "verification": { "type": "string", "maxLength": 240 }
        }
      }
    }
  }
}
